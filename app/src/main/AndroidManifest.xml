<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Psipro"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">
        
        <!-- Desabilita auto-init do Firebase para evitar crash quando a config está inválida.
             Ative novamente (remova estas linhas) após corrigir google-services.json no Firebase Console. -->
        <meta-data
            android:name="firebase_messaging_auto_init_enabled"
            android:value="false" />
        <meta-data
            android:name="firebase_installations_auto_init_enabled"
            android:value="false" />

        <!-- Google Places API - Configure sua chave real aqui -->
        <!-- <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="SUA_CHAVE_AQUI" /> -->

        <!-- Google Ads - Remover se não usar anúncios -->
        <!-- <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" /> -->

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".notification.AppointmentReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".notification.AutoavaliacaoMotivacionalReceiver"
            android:enabled="true"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false">
        </activity>

        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:label="Dashboard" />

        <activity
            android:name=".CadastroPacienteActivity"
            android:exported="false"
            android:label="Cadastro de Paciente"
            android:theme="@style/Theme.Psipro" />

        <activity
            android:name=".DetalhePacienteActivity"
            android:exported="false"
            android:label="Detalhes do Paciente" />

        <activity
            android:name=".ui.AppointmentScheduleActivity"
            android:exported="false"
            android:theme="@style/Theme.Psipro" />

        <activity
            android:name=".ui.NotificationsActivity"
            android:exported="false"
            android:theme="@style/Theme.Psipro" />

        <receiver
            android:name=".notification.AgendamentoNotificationReceiver"
            android:exported="false" />

        <activity
            android:name=".ui.PatientListActivity"
            android:exported="false"
            android:label="Lista de Pacientes" />

        <activity
            android:name=".DadosPessoaisActivity"
            android:exported="false"
            android:label="Dados Pessoais" />
        
        <activity 
            android:name=".CreateAccountActivity"
            android:theme="@style/Theme.Psipro" />
        
        <activity 
            android:name=".ui.EditProfileActivity"
            android:theme="@style/Theme.Psipro" />
        
        <activity 
            android:name=".ui.HelpActivity"
            android:theme="@style/Theme.Psipro" />
        
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Psipro.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity 
            android:name=".ui.PrivacyPolicyActivity"
            android:theme="@style/Theme.Psipro" />
        
        <activity 
            android:name=".ui.PasswordRecoveryActivity"
            android:theme="@style/Theme.Psipro" />
        
        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Psipro"/>
        
        <activity
            android:name=".NoteEditActivity"
            android:exported="false"
            android:label="Editar Anotação"
            android:theme="@style/Theme.Psipro" />
        
        <activity
            android:name=".ui.screens.QuickSessionActivity"
            android:exported="false"
            android:label="Anotação Rápida"
            android:theme="@style/Theme.Psipro" />

        <activity
            android:name=".ui.screens.AnotacoesSessaoActivity"
            android:exported="false"
            android:label="Anotações da Sessão"
            android:theme="@style/Theme.Psipro" />
        
        <activity
            android:name=".ui.screens.NovaSessaoActivity"
            android:exported="false"
            android:label="Nova Sessão"
            android:theme="@style/Theme.Psipro" />

        <activity
            android:name=".ui.SystemHealthActivity"
            android:exported="false"
            android:label="Saúde do Sistema"
            android:theme="@style/Theme.Psipro" />
        
    </application>

</manifest>