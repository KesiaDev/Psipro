<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:minHeight="480dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Foto centralizada -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/cardProfileImage"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:src="@drawable/ic_profile_placeholder"
                android:layout_gravity="center" />
        </FrameLayout>

        <!-- Nome e título -->
        <TextView
            android:id="@+id/cardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seu Nome"
            android:textStyle="bold"
            android:textSize="26sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/cardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título Profissional"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="italic"
            android:gravity="center"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/cardCrp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CRP 00000000"
            android:textColor="?attr/colorPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bronze_gold"
            android:alpha="0.2"
            android:layout_marginBottom="12dp" />

        <!-- Especialidades e Sobre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_badge"
                app:tint="@color/bronze_gold"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/cardSpecialties"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Especialidades"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_info"
                app:tint="@color/bronze_gold"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="2dp" />
            <TextView
                android:id="@+id/cardAbout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/about_professional"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Modalidades -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_schedule"
                app:tint="@color/bronze_gold"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/cardModalities"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Modalidades"
                android:textColor="?attr/colorPrimary"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bronze_gold"
            android:alpha="0.2"
            android:layout_marginBottom="12dp" />

        <!-- Contatos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_location_on"
                app:tint="@color/bronze_gold"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/cardAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Endereço"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_whatsapp"
                app:tint="@color/bronze_gold"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/cardWhatsapp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="(00) 00000-0000"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_email"
                app:tint="@color/bronze_gold"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/cardEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="email@exemplo.com"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_language"
                app:tint="@color/bronze_gold"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/cardSite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Site"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView> 