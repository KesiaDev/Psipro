<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Ícone do tipo de anexo -->
        <ImageView
            android:id="@+id/iconAttachment"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_camera_alt"
            android:tint="?attr/colorPrimary"
            android:contentDescription="Tipo de anexo" />

        <!-- Informações do anexo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/textFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="arquivo.jpg"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="imagem_sessao.jpg" />

            <TextView
                android:id="@+id/textFileInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imagem • 2.5 MB"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="Imagem • 2.5 MB" />

        </LinearLayout>

        <!-- Botão de remover -->
        <ImageButton
            android:id="@+id/btnRemove"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_delete"
            android:tint="?attr/colorError"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remover anexo" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView> 