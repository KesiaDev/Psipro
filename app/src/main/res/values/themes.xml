<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema escuro único (companion app - sem modo claro) -->
    <style name="Theme.Psipro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bronze_gold</item>
        <item name="colorPrimaryVariant">@color/bronze_gold_dark</item>
        <item name="colorOnPrimary">@color/text_black</item>
        <item name="colorSecondary">@color/secondary_bronze</item>
        <item name="colorSecondaryVariant">@color/accent_bronze</item>
        <item name="colorOnSecondary">@color/text_black</item>
        <item name="android:windowBackground">@color/background_black</item>
        <item name="colorSurface">@color/surface_black</item>
        <item name="colorOnSurface">@color/text_white</item>
        <item name="colorBackground">@color/background_black</item>
        <item name="textColorPrimary">@color/text_white</item>
        <item name="textColorSecondary">@color/text_hint</item>
        <item name="colorError">@color/error_red</item>
        <item name="colorOutline">@color/bronze_gold</item>
        <item name="dividerColor">@color/dividerColor</item>
        <item name="android:statusBarColor">@color/surface_black</item>
        <item name="android:navigationBarColor">@color/surface_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="fontFamily">@font/nunito</item>
    </style>

    <style name="Theme.Psipro.NoActionBar" parent="Theme.Psipro">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
