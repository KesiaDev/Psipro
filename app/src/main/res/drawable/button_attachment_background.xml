<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/attachment_button_secondary">
    
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/attachment_button_primary"
                android:endColor="@color/attachment_button_secondary"
                android:angle="45" />
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="@color/attachment_button_stroke" />
        </shape>
    </item>
    
</ripple> 