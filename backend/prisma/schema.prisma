// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// PsiPro Backend (single source of truth)
//
// IDs globais:
// - User, Clinic, Patient, Appointment, FinancialRecord usam `String @default(uuid())`
// - IDs são gerados no backend (clientes Android/Web nunca devem gerar IDs finais)
//
// Nota: não há migração de dados legados/incrementais neste momento.
// Se algum serviço externo ainda usar IDs incrementais, isso deve ser documentado no nível da API/integração.

// Seed configuration
// Run: npm run prisma:seed

// Origem de escrita do registro (para sync Android <-> Web).
// Observação: mantemos o campo legado `source` (app|web) para compatibilidade.
enum PatientOrigin {
  ANDROID
  WEB
}

// Tipo de plano: individual (psicólogo autônomo) ou clínica
enum PlanType {
  INDIVIDUAL
  CLINIC
}

// Papel do usuário na clínica
enum UserRole {
  OWNER
  PSYCHOLOGIST
  ASSISTANT
}

// Tipo de profissional de saúde mental
enum ProfessionalType {
  psychologist
  therapist
  psychoanalyst
  counselor
  coach
  other
}

// Clínica / Organização
model Clinic {
  id          String   @id @default(uuid())
  name        String
  cnpj        String?  @unique
  address     String?
  phone       String?
  email       String?  // Mantido para compatibilidade
  plan        String   @default("basic") // basic | professional | enterprise
  planType    PlanType @default(CLINIC)  // INDIVIDUAL = psicólogo autônomo, CLINIC = clínica
  status      String   @default("active") // active | suspended | cancelled
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  users            ClinicUser[]
  primaryUsers     User[]       @relation("PrimaryClinic")  // Usuários com esta clínica como principal
  patients         Patient[]
  appointments     Appointment[]
  financialRecords FinancialRecord[]
  payments         Payment[]
  subscriptions    Subscription[]
  anamneseModels   AnamneseModel[]
  integrations     UserIntegration[]

  @@map("clinics")
}

// Relação User ↔ Clinic (Many-to-Many com role)
model ClinicUser {
  id          String   @id @default(uuid())
  clinicId    String
  userId      String
  role        String   @default("psychologist") // owner | admin | psychologist | assistant
  status      String   @default("active") // active | inactive | invited
  
  // Permissões específicas
  canViewAllPatients Boolean @default(false)
  canEditAllPatients Boolean @default(false)
  canViewFinancial  Boolean @default(false)
  canManageUsers    Boolean @default(false)
  
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  clinic      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@index([clinicId])
  @@index([userId])
  @@map("clinic_users")
}

// Usuário profissional (psicólogo)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   // Hash bcrypt
  phone     String?
  cpf       String?  @unique
  license   String?  // CRP, etc
  
  // @deprecated Use ClinicUser. Mantido para migração. Fonte de verdade: ClinicUser.
  clinicId  String?
  clinic    Clinic?  @relation("PrimaryClinic", fields: [clinicId], references: [id], onDelete: Restrict)
  
  // Papel na clínica principal
  role      UserRole @default(OWNER)
  
  // Tipo de profissional (null = psicólogo para compatibilidade)
  professionalType ProfessionalType?
  
  // Se for psicólogo autônomo (sem clínica) - legado, preferir planType da Clinic
  isIndependent Boolean @default(true)

  // Bloqueio de login após falhas consecutivas
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?

  // LGPD: data/hora em que o usuário aceitou o termo de consentimento (app)
  lgpdAcceptedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  clinics        ClinicUser[]  // Clínicas adicionais que o usuário pertence
  patients       Patient[]     // Pacientes próprios (se independente)
  refreshTokens  RefreshToken[]
  appointments  Appointment[]
  sessions      Session[]
  payments      Payment[]
  financialRecords FinancialRecord[]
  documents      Document[]
  auditLogs      AuditLog[]
  integrations   UserIntegration[]
  handoffTokens   HandoffToken[]

  @@index([clinicId])
  @@map("users")
}

model RefreshToken {
  id              String    @id @default(uuid())
  token           String    @unique
  userId          String
  clinicId        String?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  revoked         Boolean   @default(false)
  replacedByToken String?
  deviceInfo      String?
  ipAddress       String?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Token de handoff SSO (App -> Web). Single-use, 30s expiry.
model HandoffToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  clinicId  String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("handoff_tokens")
}
model UserIntegration {
  id         String   @id @default(uuid())
  userId     String
  clinicId   String?
  provider   String   // google_calendar | whatsapp | mercadopago | stripe
  config     Json     // Tokens OAuth, chaves API (criptografar em produção)
  status     String   @default("connected") // connected | disconnected | error
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic     Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, provider])
  @@index([clinicId])
  @@map("user_integrations")
}

// Paciente
model Patient {
  id          String   @id @default(uuid())
  
  // Se paciente de clínica
  clinicId    String?  // Clínica dona do paciente
  clinicOwnerId String? // Psicólogo que cadastrou na clínica
  
  // Se paciente de psicólogo independente
  userId      String?  // Psicólogo dono (se independente)
  
  name        String
  cpf         String?
  phone       String?
  email       String?
  birthDate   DateTime?
  address     String?
  emergencyContact String?
  observations String?
  status      String   @default("Ativo") // Ativo | Inativo
  type        String?  // Adulto | Infantil | Casal
  
  // Compartilhamento (IDs dos psicólogos que podem ver/atender)
  sharedWith  String[] @default([])
  
  // Anamnese (formulário livre do detalhe do paciente - dashboard)
  anamnesis   Json?    // { items: [{ key, label, value, isCustom }], updatedAt }

  // LGPD: consentimento do paciente para tratamento de dados
  consentGiven Boolean @default(false)  // Paciente aceitou termo (ou responsável)
  consentAt    DateTime?               // Data/hora do aceite

  // Sincronização
  source      String   @default("app") // app | web
  origin      PatientOrigin @default(WEB)
  syncHash    String?  // Hash para detectar mudanças
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // Soft delete

  // Relações
  clinic      Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  sessions    Session[]
  payments    Payment[]
  documents   Document[]
  anamnesePreenchidas AnamnesePreenchida[]
  financialRecords FinancialRecord[]

  @@index([clinicId])
  @@index([deletedAt])
  @@index([userId])
  @@index([syncHash])
  @@map("patients")
}

// Modelo de anamnese (template)
model AnamneseModel {
  id        String   @id @default(uuid())
  clinicId  String?  // Clínica dona do modelo (null = modelo global/seed)
  userId    String?  // Psicólogo dono (se independente)
  nome      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic    Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  campos    AnamneseCampo[]
  preenchidas AnamnesePreenchida[]

  @@index([clinicId])
  @@index([userId])
  @@map("anamnese_models")
}

// Campo do modelo de anamnese
model AnamneseCampo {
  id         String  @id @default(uuid())
  modeloId   String
  tipo       String  // TEXTO_CURTO, TEXTO_LONGO, DATA, SELECAO_UNICA, MULTIPLA_ESCOLHA, TITULO
  label      String
  opcoes     String? // JSON para opções de seleção
  obrigatorio Boolean @default(false)
  ordem      Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  modelo    AnamneseModel @relation(fields: [modeloId], references: [id], onDelete: Cascade)

  @@index([modeloId])
  @@map("anamnese_campos")
}

// Anamnese preenchida por paciente
model AnamnesePreenchida {
  id             String   @id @default(uuid())
  patientId      String
  modeloId       String
  respostas      Json     // campoId -> resposta
  assinaturaPath String?
  data           DateTime
  versao         Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient  Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  modelo   AnamneseModel @relation(fields: [modeloId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([modeloId])
  @@map("anamnese_preenchidas")
}

// Agendamento / Consulta
model Appointment {
  id          String   @id @default(uuid())
  
  // Se de clínica
  clinicId    String?
  
  // Psicólogo que vai atender
  userId      String
  patientId   String
  scheduledAt DateTime
  duration    Int      @default(60) // minutos
  type        String?  // Consulta regular | Retorno | etc
  notes       String?
  status      String   @default("agendada") // agendada | confirmada | cancelada | realizada
  
  // Sincronização
  source      String   @default("app")
  syncHash    String?
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // Soft delete

  // Relações
  clinic      Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  session     Session?

  @@index([clinicId])
  @@index([userId])
  @@index([patientId])
  @@index([scheduledAt])
  @@index([deletedAt])
  @@index([syncHash])
  @@map("appointments")
}

// Sessão realizada
model Session {
  id            String   @id @default(uuid())
  userId        String
  patientId     String
  appointmentId String?  @unique
  date          DateTime
  duration      Int      @default(60)
  status        String   @default("realizada") // realizada | falta | cancelada
  type          String?  // Consulta | Retorno | etc
  notes         String?  // Anotações da sessão
  clinicalData  Json?    // Prontuário: estado emocional, evolução, técnicas, tarefas, risco

  // Inteligência Clínica (transcrição + insights IA)
  transcript    String?  // Transcrição de voz da sessão
  summary       String?  // Resumo clínico gerado por IA
  themes        Json?    // Principais temas discutidos
  emotions      Json?    // Emoções predominantes
  actionItems   Json?    // Tarefas/encaminhamentos terapêuticos
  riskFlags     Json?    // Sinais de alerta emocional

  // Sincronização
  source        String   @default("app")
  syncHash      String?
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime? // Soft delete

  // Relações
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  payment       Payment?
  financialRecord FinancialRecord?

  @@index([userId])
  @@index([deletedAt])
  @@index([patientId])
  @@index([date])
  @@index([syncHash])
  @@map("sessions")
}

// Pagamento
model Payment {
  id            String   @id @default(uuid())
  userId        String
  patientId     String
  clinicId      String?  // Isolamento multi-tenant (nullable para migração)
  sessionId     String?  @unique
  sessionNumber Int?     // Número da sessão (max+1 ao criar cobrança automática)
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime
  method        String?  // Dinheiro | PIX | Cartão | etc
  status        String   @default("pago") // pago | pendente | cancelado
  notes         String?
  
  // Sincronização
  source      String   @default("app")
  syncHash    String?
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // Soft delete

  // Relações
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic      Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([patientId, sessionNumber])
  @@index([userId])
  @@index([clinicId])
  @@index([patientId])
  @@index([date])
  @@index([status])
  @@index([syncHash])
  @@index([deletedAt])
  @@map("payments")
}

// Registro financeiro consolidado
model FinancialRecord {
  id            String   @id @default(uuid())
  userId        String
  clinicId      String?  // Isolamento multi-tenant (nullable para migração)
  date          DateTime
  type          String   // receita | despesa
  amount        Decimal  @db.Decimal(10, 2)
  description   String?
  category      String?
  patientId     String?  // Paciente (opcional, para sessões/agendamentos)
  sessionId     String?  @unique // Vínculo com sessão (cobrança pendente)
  status        String?  @default("pendente") // pendente | pago
  paymentMethod String?  // PIX | Dinheiro | Cartão | etc

  // Sincronização
  source      String   @default("app")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic      Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clinicId])
  @@index([date])
  @@index([patientId])
  @@index([sessionId])
  @@index([status])
  @@map("financial_records")
}

// Documento / Arquivo
model Document {
  id          String   @id @default(uuid())
  userId      String
  patientId   String?
  name        String
  type        String   // Termo | Relatório | Receita | etc
  fileUrl     String?  // URL do arquivo (S3, local, etc)
  fileSize    Int?
  mimeType    String?
  status      String   @default("Ativo")
  content     Json?    // Conteúdo HTML/JSON do app (conteudo, assinaturas)
  
  // Sincronização
  source      String   @default("app")
  syncHash    String?
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([patientId])
  @@index([syncHash])
  @@map("documents")
}

// Insight gerado (futuro - IA)
model Insight {
  id          String   @id @default(uuid())
  userId      String
  type        String   // clinico | financeiro | agenda
  message     String
  context     Json?    // Dados contextuais
  priority    String   @default("info") // info | warning | success
  dismissed   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([dismissed])
  @@map("insights")
}

// Assinatura (preparação para Stripe futuro)
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

model Subscription {
  id                    String             @id @default(uuid())
  clinicId              String
  status                SubscriptionStatus @default(ACTIVE)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  currentPeriodEnd      DateTime?
  
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  clinic                Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("subscriptions")
}

// Auditoria enterprise — eventos críticos para rastreabilidade (LGPD)
// action: CREATE | UPDATE | DELETE | ANONYMIZE
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  clinicId  String   // Clínica ativa ou user.clinicId / primeira ClinicUser
  action    String   // CREATE | UPDATE | DELETE | ANONYMIZE
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clinicId])
  @@index([entity])
  @@index([createdAt])
  @@index([clinicId, createdAt])
  @@map("audit_logs")
}

// Consentimento LGPD — registro de aceite do paciente/usuário
model LgpdConsent {
  id        String   @id @default(uuid())
  userId    String   // Usuário (psicólogo) que registrou o consentimento
  clinicId  String   // Clínica vinculada
  patientId String?  // Paciente que consentiu (null = consentimento do profissional)
  type      String   // data_processing | marketing | research | all
  version   String   @default("1.0") // Versão do termo aceito
  accepted  Boolean  @default(true)
  ipAddress String?
  userAgent String?
  revokedAt DateTime? // null = consentimento ativo
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clinicId])
  @@index([patientId])
  @@index([clinicId, patientId])
  @@map("lgpd_consents")
}

// Solicitações de acesso beta
model BetaRequest {
  id         String   @id @default(uuid())
  name       String
  email      String
  clinicName String?
  message    String?
  createdAt  DateTime @default(now())

  @@map("beta_requests")
}

